{
  "servers": [
    {
      "name": "memory_write",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "awfulclaw_mcp.memory_write"
      ]
    },
    {
      "name": "memory_search",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "awfulclaw_mcp.search"
      ]
    },
    {
      "name": "schedule",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "awfulclaw_mcp.schedule"
      ]
    },
    {
      "name": "skills",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "awfulclaw_mcp.skills"
      ]
    },
    {
      "name": "env_manager",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "awfulclaw_mcp.env_manager"
      ]
    },
    {
      "name": "mcp_manager",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "awfulclaw_mcp.mcp_manager"
      ]
    },
    {
      "name": "imap",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "awfulclaw_mcp.imap"
      ],
      "env": {
        "IMAP_HOST": "${IMAP_HOST}",
        "IMAP_PORT": "${IMAP_PORT}",
        "IMAP_USER": "${IMAP_USER}",
        "IMAP_PASSWORD": "${IMAP_PASSWORD}"
      },
      "env_required": [
        "IMAP_HOST",
        "IMAP_USER",
        "IMAP_PASSWORD"
      ]
    },
    {
      "name": "gcal",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "awfulclaw_mcp.gcal"
      ],
      "env": {
        "GOOGLE_CLIENT_SECRET_PATH": "${GOOGLE_CLIENT_SECRET_PATH}"
      },
      "env_required": [
        "GOOGLE_CLIENT_SECRET_PATH"
      ]
    },
    {
      "name": "owntracks",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "awfulclaw_mcp.owntracks"
      ],
      "env": {
        "OWNTRACKS_URL": "${OWNTRACKS_URL}",
        "OWNTRACKS_USER": "${OWNTRACKS_USER}",
        "OWNTRACKS_DEVICE": "${OWNTRACKS_DEVICE}"
      },
      "env_required": [
        "OWNTRACKS_URL"
      ]
    },
    {
      "name": "obsidian",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "awfulclaw_mcp.obsidian"
      ],
      "env": {
        "OBSIDIAN_VAULT": "${OBSIDIAN_VAULT}"
      },
      "env_required": [
        "OBSIDIAN_VAULT"
      ]
    },
    {
      "name": "github",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "env_required": [
        "GITHUB_PERSONAL_ACCESS_TOKEN"
      ]
    },
    {
      "name": "homeassistant",
      "command": "npx",
      "args": [
        "mcp-remote",
        "${HASS_URL}",
        "--header",
        "Authorization: Bearer ${HASS_TOKEN}"
      ],
      "env_required": [
        "HASS_URL",
        "HASS_TOKEN"
      ]
    }
  ]
}
