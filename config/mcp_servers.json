{
  "mcpServers": {
    "memory": {
      "command": "/opt/homebrew/bin/uv",
      "args": ["run", "python", "-m", "agent.mcp.memory"],
      "env": {
        "DB_PATH": "state/store.db",
        "GOVERNANCE_MODEL": "${AWFULCLAW_GOVERNANCE_MODEL}"
      }
    },
    "schedule": {
      "command": "/opt/homebrew/bin/uv",
      "args": ["run", "python", "-m", "agent.mcp.schedule"],
      "env": {
        "DB_PATH": "state/store.db",
        "GOVERNANCE_MODEL": "${AWFULCLAW_GOVERNANCE_MODEL}"
      }
    },
    "skills": {
      "command": "/opt/homebrew/bin/uv",
      "args": ["run", "python", "-m", "agent.mcp.skills"]
    },
    "eventkit": {
      "command": "/opt/homebrew/bin/uv",
      "args": ["run", "python", "-m", "agent.mcp.eventkit"]
    },
    "contacts": {
      "command": "/opt/homebrew/bin/uv",
      "args": ["run", "python", "-m", "agent.mcp.contacts"]
    },
    "weather": {
      "command": "/opt/homebrew/bin/uv",
      "args": ["run", "python", "-m", "agent.mcp.weather"],
      "env": {
        "DB_PATH": "state/store.db"
      }
    },
    "file_read": {
      "command": "/opt/homebrew/bin/uv",
      "args": ["run", "python", "-m", "agent.mcp.file_read"]
    },
    "imap": {
      "command": "/opt/homebrew/bin/uv",
      "args": ["run", "python", "-m", "agent.mcp.imap"],
      "env": {
        "IMAP_HOST": "${AWFULCLAW_IMAP__HOST}",
        "IMAP_PORT": "${AWFULCLAW_IMAP__PORT}",
        "IMAP_USERNAME": "${AWFULCLAW_IMAP__USERNAME}",
        "IMAP_PASSWORD": "${AWFULCLAW_IMAP__PASSWORD}"
      }
    },
    "owntracks": {
      "command": "/opt/homebrew/bin/uv",
      "args": ["run", "python", "-m", "agent.mcp.owntracks"],
      "env": {
        "DB_PATH": "state/store.db",
        "OWNTRACKS_URL": "${AWFULCLAW_OWNTRACKS__URL}"
      }
    },
    "obsidian": {
      "command": "/opt/homebrew/bin/uv",
      "args": ["run", "python", "-m", "agent.mcp.obsidian"],
      "env": {
        "VAULT_PATH": "${AWFULCLAW_OBSIDIAN_VAULT}"
      }
    },
    "homeassistant": {
      "url": "${AWFULCLAW_HASS_URL}",
      "headers": {
        "Authorization": "Bearer ${AWFULCLAW_HASS_TOKEN}"
      }
    }
  }
}
