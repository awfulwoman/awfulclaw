; macOS sandbox profile for the claude CLI subprocess.
; Invoked via: sandbox-exec -f sandbox.sb -D MEMORY_PATH=/abs/path/to/memory
;
; Policy: deny file writes everywhere, allow only memory/ and claude's own
; dependencies. Network access is allowed (Claude CLI calls the API).

(version 1)

; Start with a default-deny posture for writes; allow everything else.
(allow default)
(deny file-write*)

; Allow writes to the memory directory (passed in via -D MEMORY_PATH=...).
(allow file-write* (subpath (param "MEMORY_PATH")))

; Allow writes to the project .env file (passed in via -D PROJECT_PATH=...).
(allow file-write*
  (literal (string-append (param "PROJECT_PATH") "/.env"))
  (literal (string-append (param "PROJECT_PATH") "/.env.tmp")))

; Allow writes to standard macOS temp/cache dirs needed by the CLI runtime.
(allow file-write*
  (subpath "/tmp")
  (subpath "/var/folders")
  (subpath "/private/tmp")
  (subpath "/private/var/folders"))

; Allow writes to the user's home .claude dir (CLI state / session files).
(allow file-write* (subpath (string-append (param "HOME") "/.claude")))

; Allow uv to write to its cache (needed when MCP servers are spawned as children).
(allow file-write* (subpath (string-append (param "HOME") "/.cache/uv")))

; Network is unrestricted — Claude CLI must reach the Anthropic API.
(allow network*)
